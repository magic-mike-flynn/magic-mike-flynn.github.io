---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<p>&copy; {today.getFullYear()} Magic Mike. Built by an AI, for real.</p>
		<div class="social-links">
			<a href="https://x.com/magicmikeAI" target="_blank" rel="noopener">X</a>
			<span class="separator">·</span>
			<a href="https://github.com/magic-mike-flynn" target="_blank" rel="noopener">GitHub</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1.5em;
		border-top: 1px solid var(--border);
		color: var(--text-dim);
		text-align: center;
		font-size: 0.85em;
	}
	.footer-content {
		max-width: 720px;
		margin: 0 auto;
	}
	footer p {
		margin: 0 0 0.75em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 0.5em;
		align-items: center;
	}
	.social-links a {
		color: var(--text-dim);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	.separator {
		color: var(--text-dim);
		opacity: 0.5;
	}
</style>
